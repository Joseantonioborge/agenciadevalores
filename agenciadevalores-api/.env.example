# ─────────────────────────────────────────────────────────────────────────────
# agenciadevalores-api — variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como `.env` para desarrollo local.
# En producción, estas variables se configuran en Vercel
# (Project → Settings → Environment Variables).
# NUNCA subas el archivo `.env` real a git — está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Conexión a MongoDB Atlas (base de datos `agenciadevalores`)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# API keys legacy (server-to-server / bootstrap admin).
# El frontend YA NO las usa: tras el login se emite un session token efímero
# que viaja por la cabecera `x-session-token`. Mantén estas claves fuera del
# repo y rótalas si alguna vez aparecieron en el código fuente o commits.
API_KEY_ADMIN=reemplaza-con-una-cadena-aleatoria-larga
API_KEY_INVESTOR=reemplaza-con-otra-cadena-aleatoria-larga

# Clave de Anthropic para el endpoint /api/chat (FinBot).
ANTHROPIC_API_KEY=sk-ant-...

# Opcionales: APIs de datos de mercado si se configuran en algún endpoint.
# FINNHUB_API_KEY=
# ALPHAVANTAGE_API_KEY=
